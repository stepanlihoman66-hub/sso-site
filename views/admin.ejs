<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Админ-панель - ССО</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header', { user: admin }) %>
    
    <div class="admin-container">
        <h1>Админ-панель</h1>
        
        <!-- Настройка префикса подразделения -->
        <div class="admin-section">
            <h2>⚙️ Настройки подразделения</h2>
            <div class="prefix-settings">
                <label for="unitPrefix">Префикс подразделения:</label>
                <input type="text" id="unitPrefix" value="<%= admin.unitPrefix %>">
                <button onclick="updatePrefix()" class="btn-save">Сохранить для всех</button>
            </div>
        </div>
        
        <!-- Админ-консоль (только для superadmin) -->
        <% if (admin.role === 'superadmin') { %>
        <div class="admin-section">
            <h2>🖥️ Управление сервером</h2>
            <a href="/admin/console" class="btn-console">🔧 Настройки сайта (консоль)</a>
        </div>
        <% } %>
        
        <!-- Управление пользователями -->
        <div class="admin-section">
            <h2>👥 Пользователи</h2>
            <table class="admin-table">
                <thead>
                    <tr>
                        <th>Discord</th>
                        <th>Позывной</th>
                        <th>Префикс</th>
                        <th>Роль</th>
                        <th>Статус</th>
                        <th>Верификация</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    <% for(var index = 0; index < users.length; index++) { 
                        var user = users[index];
                    %>
                    <tr>
                        <td><%= user.username %></td>
                        <td><%= user.callsign %></td>
                        <td>
                            <input type="text" class="user-prefix" data-id="<%= user.id %>" value="<%= user.unitPrefix %>" style="width: 80px;">
                        </td>
                        <td>
                            <select class="user-role" data-id="<%= user.id %>">
                                <option value="user" <% if(user.role === 'user') { %>selected<% } %>>Опер. ССО</option>
                                <option value="sro_tuman" <% if(user.role === 'sro_tuman') { %>selected<% } %>>СРО "Туман"</option>
                                <option value="admin" <% if(user.role === 'admin') { %>selected<% } %>>Администратор</option>
                                <% if(admin.role === 'superadmin') { %>
                                <option value="superadmin" <% if(user.role === 'superadmin') { %>selected<% } %>>Главный админ</option>
                                <% } %>
                            </select>
                        </td>
                        <td><% if(user.isBanned) { %>🔴 Забанен<% } else { %>🟢 Активен<% } %></td>
                        <td><% if(user.verified) { %>✅ Верифицирован<% } else { %>❌ Не верифицирован<% } %></td>
                        <td>
                            <button onclick="banUser(<%= user.id %>)" class="btn-ban">
                                <% if(user.isBanned) { %>Разбанить<% } else { %>Забанить<% } %>
                            </button>
                            <button onclick="updateUserPrefix(<%= user.id %>)" class="btn-update">Префикс</button>
                            <button onclick="updateUserRole(<%= user.id %>)" class="btn-update">Роль</button>
                            <% if(admin.role === 'superadmin' && user.id !== admin.id && user.role !== 'superadmin') { %>
                            <button onclick="deleteUser(<%= user.id %>)" class="btn-delete" style="background: #8b0000;">🗑️ Удалить</button>
                            <% } %>
                        </td>
                    </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
        
        <!-- Управление постами -->
        <div class="admin-section">
            <h2>📝 Посты</h2>
            <% for(var index = 0; index < posts.length; index++) { 
                var post = posts[index];
            %>
            <div class="post admin-post">
                <div class="post-header">
                    <strong><%= post.User.username %></strong>
                    <span class="post-date"><%= new Date(post.createdAt).toLocaleString() %></span>
                    <button class="delete-post" data-id="<%= post.id %>">Удалить</button>
                </div>
                <div class="post-content"><%= post.content %></div>
                <% if(post.imageUrl) { %>
                    <img src="<%= post.imageUrl %>" style="max-width: 200px; margin-top: 10px;">
                <% } %>
            </div>
            <% } %>
        </div>
        
        <div class="admin-section">
            <a href="/appeals" class="btn-appeals">📋 Перейти к обращениям</a>
        </div>
    </div>
    
    <style>
        .prefix-settings {
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-width: 400px;
        }
        .prefix-settings input {
            padding: 8px;
            background: #1a2f24;
            border: 1px solid #4a7c59;
            color: white;
            border-radius: 4px;
        }
        .btn-save, .btn-ban, .btn-update, .btn-delete, .btn-console {
            padding: 5px 10px;
            margin: 2px;
            background: #4a7c59;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        .btn-ban {
            background: #8b3a3a;
        }
        .btn-update {
            background: #2c4a3a;
        }
        .btn-delete {
            background: #8b0000;
        }
        .btn-console {
            background: #3498db;
            font-size: 14px;
            padding: 8px 16px;
            text-decoration: none;
            display: inline-block;
        }
        .admin-table input, .admin-table select {
            background: #1a2f24;
            border: 1px solid #4a7c59;
            color: white;
            padding: 4px;
            border-radius: 4px;
        }
    </style>
    
    <script>
        // Обновление глобального префикса
        async function updatePrefix() {
            var prefix = document.getElementById('unitPrefix').value;
            var response = await fetch('/admin/update-prefix', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ prefix: prefix })
            });
            if (response.ok) {
                alert('Префикс обновлен для всех!');
                location.reload();
            } else {
                alert('Ошибка при обновлении');
            }
        }
        
        // Обновление префикса пользователя
        async function updateUserPrefix(userId) {
            var input = document.querySelector('.user-prefix[data-id="' + userId + '"]');
            var prefix = input.value;
            var response = await fetch('/admin/user/' + userId + '/prefix', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ prefix: prefix })
            });
            if (response.ok) {
                alert('Префикс обновлен!');
            } else {
                alert('Ошибка при обновлении');
            }
        }
        
        // Обновление роли пользователя
        async function updateUserRole(userId) {
            var select = document.querySelector('.user-role[data-id="' + userId + '"]');
            var role = select.value;
            var response = await fetch('/admin/user/' + userId + '/role', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ role: role })
            });
            if (response.ok) {
                alert('Роль обновлена!');
                location.reload();
            } else {
                alert('Ошибка при обновлении');
            }
        }
        
        // Бан/разбан пользователя
        async function banUser(userId) {
            var response = await fetch('/admin/user/' + userId + '/ban', { method: 'POST' });
            if (response.ok) {
                location.reload();
            } else {
                alert('Ошибка при бане');
            }
        }
        
        // Удаление пользователя
        async function deleteUser(userId) {
            if (confirm('ВНИМАНИЕ! Это действие полностью удалит пользователя и все его данные. Продолжить?')) {
                var response = await fetch('/admin/user/' + userId + '/delete', { method: 'POST' });
                if (response.ok) {
                    alert('Пользователь удален');
                    location.reload();
                } else {
                    var text = await response.text();
                    alert('Ошибка: ' + text);
                }
            }
        }
        
        // Удаление поста
        var deleteButtons = document.querySelectorAll('.delete-post');
        for (var i = 0; i < deleteButtons.length; i++) {
            deleteButtons[i].addEventListener('click', function(e) {
                if (confirm('Удалить пост?')) {
                    var postId = this.getAttribute('data-id');
                    fetch('/admin/post/' + postId, { method: 'DELETE' }).then(function(response) {
                        if (response.ok) {
                            this.closest('.post').remove();
                        }
                    }.bind(this));
                }
            });
        }
    </script>
</body>
</html>