<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Анонимное обращение - ССО</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <%- include('partials/header') %>
    
    <div class="appeal-create-container">
        <div class="appeal-create-card">
            <h1>Анонимное обращение к командиру</h1>
            <p>Ваше обращение будет видно только командиру. Ваше имя не будет отображаться в общем доступе.</p>
            
            <form action="/appeals/create" method="POST">
                <div class="form-group">
                    <label for="content">Текст обращения:</label>
                    <textarea name="content" id="content" rows="6" required 
                              placeholder="Опишите вашу проблему или предложение..."></textarea>
                </div>
                <button type="submit">Отправить обращение</button>
                <a href="/" class="btn-cancel">Отмена</a>
            </form>
        </div>
    </div>
    
    <style>
        .appeal-create-container {
            max-width: 600px;
            margin: 2rem auto;
            padding: 0 1rem;
        }
        
        .appeal-create-card {
            background: #1e2f26;
            padding: 2rem;
            border-radius: 8px;
        }
        
        .appeal-create-card h1 {
            margin-bottom: 1rem;
            color: #8bc34a;
        }
        
        .appeal-create-card p {
            margin-bottom: 1.5rem;
            color: #a0a0a0;
        }
        
        textarea {
            width: 100%;
            padding: 0.5rem;
            background: #1a2f24;
            border: 1px solid #4a7c59;
            color: #e0e0e0;
            border-radius: 4px;
            font-family: inherit;
            resize: vertical;
        }
        
        button {
            margin-top: 1rem;
            margin-right: 0.5rem;
            padding: 0.75rem 1.5rem;
            background: #4a7c59;
            color: white;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        
        button:hover {
            background: #5c9e6b;
        }
        
        .btn-cancel {
            display: inline-block;
            margin-top: 1rem;
            padding: 0.75rem 1.5rem;
            background: #8a8a8a;
            color: white;
            text-decoration: none;
            border-radius: 4px;
        }
        
        .btn-cancel:hover {
            background: #a0a0a0;
        }
    </style>
</body>
</html>